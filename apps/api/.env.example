NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker Compose):
DATABASE_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"
DIRECT_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"

# Supabase (deployed):
# DATABASE_URL must use the CONNECTION POOLER URL (port 6543, PgBouncer).
# Append ?pgbouncer=true&connection_limit=1 for serverless functions.
# Example:
#   DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL must use the DIRECT connection URL (port 5432).
# Used only by the Prisma CLI (migrate, introspect, studio). Never set in Vercel.
# Example:
#   DIRECT_URL="postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate with: openssl rand -base64 32
# NEVER commit the real value. Set this as a secret in Vercel dashboard.
JWT_SECRET=change-me-to-a-secure-32-char-minimum-secret
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcards in production.
# In Vercel set this to your deployed frontend URL.
# Phase 2 renames this to CORS_ORIGINS — keep in sync with cors plugin.
CORS_ORIGINS=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
