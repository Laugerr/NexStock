# ── API URL ───────────────────────────────────────────────────────────────────
# Leave empty when the frontend and API are deployed as a single Vercel project
# (both on the same domain). All /api/* calls go to the same origin.
#
# Set this ONLY when deploying as two separate Vercel projects:
#   VITE_API_URL=https://nexstock-api.vercel.app
#
# In local dev this is also left empty — Vite proxies /api/* to localhost:3001.
VITE_API_URL=
