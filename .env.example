# ==================== ENVIRONMENT ====================
NODE_ENV=development

# ==================== API ====================
PORT=3001
HOST=0.0.0.0

# ==================== DATABASE ====================
DATABASE_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"

# ==================== REDIS ====================
REDIS_URL="redis://localhost:6379"

# ==================== AUTH ====================
# Must be at least 32 chars — generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=7d

# ==================== CORS ====================
CORS_ORIGIN=http://localhost:5173

# ==================== LOGGING ====================
LOG_LEVEL=info
