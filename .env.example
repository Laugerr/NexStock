# ==================== ENVIRONMENT ====================
NODE_ENV=development

# ==================== API SERVER ====================
PORT=3001
HOST=0.0.0.0

# ==================== DATABASE ====================
# LOCAL DEV (Docker Compose):
DATABASE_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"
DIRECT_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"
#
# SUPABASE (deployed):
# DATABASE_URL → connection pooler URL (PgBouncer, port 6543)
#   Add ?pgbouncer=true&connection_limit=1 for serverless Vercel functions.
#   DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL → direct connection URL (port 5432). CLI/migrations only.
#   DIRECT_URL="postgresql://postgres.[ref]:[pw]@db.[ref].supabase.co:5432/postgres"

# ==================== AUTH ====================
# Must be at least 32 chars — generate with: openssl rand -base64 32
# Set as a secret (not plaintext env var) in Vercel dashboard.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=7d

# ==================== CORS ====================
# Comma-separated list of allowed origins. No wildcards in production.
# Phase 2 renames this to CORS_ORIGINS — keep in sync with cors plugin.
CORS_ORIGINS=http://localhost:5173

# ==================== LOGGING ====================
LOG_LEVEL=info
