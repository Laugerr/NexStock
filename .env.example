# ==================== ENVIRONMENT ====================
NODE_ENV=development

# ==================== API SERVER ====================
PORT=3001
HOST=0.0.0.0

# ==================== DATABASE ====================
# LOCAL DEV (Docker Compose):
DATABASE_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"
DIRECT_URL="postgresql://nexstock:nexstock_dev@localhost:5432/nexstock"
#
# SUPABASE (production):
# DATABASE_URL → PgBouncer pooler URL (port 6543, transaction mode)
#   Append ?pgbouncer=true&connection_limit=1 for Vercel serverless functions.
#   DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL → Direct connection URL (port 5432). Used only by Prisma CLI.
#   Never set this in Vercel — set it locally for running migrations.
#   DIRECT_URL="postgresql://postgres.[ref]:[pw]@db.[ref].supabase.co:5432/postgres"

# ==================== AUTH ====================
# REQUIRED. Must be at least 32 chars.
# Generate with: openssl rand -base64 32
# Set as a Vercel Secret (encrypted), NOT a plain env var.
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=7d

# ==================== CORS ====================
# Comma-separated list of allowed origins. No wildcards in production.
# In Vercel: set to your deployed frontend URL, e.g. https://nexstock.vercel.app
CORS_ORIGINS=http://localhost:5173

# ==================== LOGGING ====================
LOG_LEVEL=info
